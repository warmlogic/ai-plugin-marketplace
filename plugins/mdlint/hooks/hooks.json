{
  "description": "Auto-format markdown on Write/Edit",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/mdlint.sh"
          }
        ]
      }
    ]
  }
}
